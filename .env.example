# Pooled URL for the app (Neon: host contains "-pooler")
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct URL for Prisma CLI only — same user/db, host WITHOUT "-pooler" (required for migrate)
# https://neon.com/docs/guides/prisma-migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"

# --- If migrate deploy fails with P1002 (advisory lock timeout), even on DIRECT_URL ---
# 1) Stop `npm run dev` and close Prisma Studio / other DB clients (they keep sessions open).
# 2) Neon → SQL Editor: SELECT * FROM pg_locks WHERE locktype = 'advisory';
#    If a stale session holds the lock, Neon → Monitoring → terminate that connection,
#    or briefly suspend/resume the branch compute.
# 3) Or run scripts/manual-apply-vulnerable-dep-enum.sql in Neon, then:
#    npx prisma migrate resolve --applied 20260401180000_add_vulnerable_dep_kind

AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Optional caps (Pro / Enterprise) when you wire billing
PRO_MAX_REPOS=50
ENTERPRISE_MAX_REPOS=500

# Inngest: local dev — run `npm run inngest:dev` in a second terminal, then:
INNGEST_DEV=1

# Production / cloud Inngest
# INNGEST_SIGNING_KEY=
# INNGEST_EVENT_KEY=

# Optional: run clone + metrics in the same Node process (development only; can time out on large repos)
# ANALYSIS_INLINE=true

# Barely-used heuristic: days since last commit on a path + static unused finding
# BARELY_USED_IDLE_DAYS=180

# Optional: POST JSON when a completed run includes critical dependency advisories (Slack webhook, etc.)
# CRITICAL_VULN_WEBHOOK_URL=

# Stripe (Pro checkout + Customer Portal + webhooks)
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_PRO=price_...   (from the product’s Pricing — not the product id prod_...)
# STRIPE_WEBHOOK_SECRET=
# Configure the Customer Portal in Stripe Dashboard (products, cancel, etc.).
